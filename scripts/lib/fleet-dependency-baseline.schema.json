{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trellis.local/schemas/fleet-dependency-baseline.schema.json",
  "title": "Trellis fleet dependency baseline",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policy", "toolchains", "packages", "security_floors", "exceptions"],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "source_ref": { "type": "string", "minLength": 1 },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shared_project_minimum", "direct_versions", "peer_versions", "expired_exceptions"],
      "properties": {
        "shared_project_minimum": { "type": "integer", "minimum": 2 },
        "direct_versions": { "const": "exact-per-lane" },
        "peer_versions": { "const": "compatible-range" },
        "expired_exceptions": { "const": "fail" }
      }
    },
    "toolchains": { "$ref": "#/$defs/entries" },
    "packages": { "$ref": "#/$defs/entries" },
    "security_floors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ecosystem", "name", "projects"],
        "properties": {
          "ecosystem": { "type": "string" },
          "name": { "type": "string" },
          "projects": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "forbidden": { "type": "boolean" },
          "branches": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["major", "minimum"],
              "properties": {
                "major": { "type": "integer", "minimum": 0 },
                "minimum": { "type": "string" }
              }
            }
          }
        },
        "oneOf": [
          { "required": ["forbidden"] },
          { "required": ["branches"] }
        ]
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "project", "workspace", "reason", "owner", "replacement_condition", "expires_on"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "project": { "type": "string", "minLength": 1 },
          "workspace": { "type": "string", "minLength": 1 },
          "ecosystem": { "type": "string" },
          "package": { "type": "string" },
          "reason": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "replacement_condition": { "type": "string", "minLength": 1 },
          "expires_on": { "type": "string", "format": "date" }
        }
      }
    }
  },
  "$defs": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "lanes"],
        "properties": {
          "ecosystem": { "type": "string" },
          "name": { "type": "string", "minLength": 1 },
          "lanes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "version", "projects"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "version": { "type": "string", "minLength": 1 },
                "projects": { "type": "array", "minItems": 1, "items": { "type": "string" } },
                "workspaces": { "type": "array", "items": { "type": "string" } },
                "match": { "enum": ["exact", "major"] },
                "required": { "type": "boolean" },
                "reason": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
