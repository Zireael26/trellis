#!/usr/bin/env sh
# Trellis canonical pre-push — the cross-harness merge gate (DL-P7-03).
# 1. Blocks direct pushes to main/master (Trellis PR-flow policy).
#    Override for emergencies: TRELLIS_ALLOW_MAIN_PUSH=1 git push
# 2. Invokes the process-gate aggregator (run-all.sh) in the right mode:
#    merge (strict) when a ref targets main/master, else push (PR-shape
#    downgrade). run-all wraps tests + secrets + security-diff + analyze etc.,
#    so this hook no longer carries standalone typecheck/test/security blocks.
#
# POSIX sh: no bashisms (no arrays, no [[ ]], no 'local'). The bash gate
# scripts are invoked via `bash`.

set -e

# --- Trellis PR-flow guard ---
# Git passes refs via stdin: <local_ref> <local_sha> <remote_ref> <remote_sha>
# REUSE this loop to also pick the run-all MODE + RANGE:
#   - MODE=merge if any pushed ref targets refs/heads/main|master, else push.
#   - RANGE=<remote_sha>..<local_sha> for the main-targeting ref; a new branch
#     (all-zero remote_sha) leaves RANGE empty so run-all uses its own default.
MODE=push
RANGE=""
# local_ref is a positional placeholder for the 1st stdin field (unused here).
# shellcheck disable=SC2034
while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/master)
      # Target is the merge boundary: strict gate regardless of policy override.
      MODE=merge
      case "$remote_sha" in
        *[!0]*)
          # Only build the range if the remote tip is present in the local
          # object store. A non-zero remote_sha that is missing locally (remote
          # ahead, force-pushed/rewritten ref, shallow clone) would otherwise
          # build an unresolvable <remote_sha>..<local_sha> range -> run-diff
          # resolves it to ZERO files -> the security gate fails OPEN. Leave
          # RANGE empty in that case so run-all falls back to its main..HEAD
          # default and actually scans the diff.
          if git cat-file -e "$remote_sha^{commit}" 2>/dev/null; then
            RANGE="$remote_sha..$local_sha"
          else
            RANGE=""
          fi
          ;;
        *)      RANGE="" ;;
      esac
      if [ "${TRELLIS_ALLOW_MAIN_PUSH:-0}" != "1" ]; then
        echo "[pre-push] Direct push to $remote_ref blocked by Trellis policy." >&2
        echo "[pre-push] Open a branch + PR. Emergency override: TRELLIS_ALLOW_MAIN_PUSH=1 git push" >&2
        exit 1
      fi
      echo "[pre-push] TRELLIS_ALLOW_MAIN_PUSH=1 set; allowing direct push to $remote_ref." >&2
      ;;
  esac
done

echo "[pre-push] Trellis verification starting (mode=$MODE)..."

# --- process-gate merge gate ---
# Locate run-all.sh: .claude first, .agents fallback. Invoked via `bash`, so a
# missing exec bit is irrelevant — test for a regular file (-f), not -x.
RUNALL=""
if [ -f .claude/skills/process-gate/scripts/run-all.sh ]; then
  RUNALL=.claude/skills/process-gate/scripts/run-all.sh
elif [ -f .agents/skills/process-gate/scripts/run-all.sh ]; then
  RUNALL=.agents/skills/process-gate/scripts/run-all.sh
fi

if [ -z "$RUNALL" ]; then
  echo "[pre-push] process-gate not installed — skipping (run scripts/onboard-project.sh to install)"
  exit 0
fi

# Build args without arrays: --mode always, --range only when derived.
set -- --mode="$MODE"
if [ -n "$RANGE" ]; then
  set -- "$@" --range="$RANGE"
fi

# Capture rc without tripping `set -e`: commands in an `if` test are exempt,
# so a WARN (2) or BLOCK (1) is captured instead of aborting the hook early.
if bash "$RUNALL" "$@"; then
  rc=0
else
  rc=$?
fi

# Fail-closed rc mapping: only the two known-good codes pass; ANYTHING else
# (including an unexpected rc from a crash/kill) blocks. This is the live merge
# boundary — the default MUST be to block, never to pass.
case "$rc" in
  0)
    echo "[pre-push] process-gate ok"
    exit 0
    ;;
  2)
    echo "[pre-push] process-gate NEEDS CHANGES (warn) — not blocking this push." >&2
    exit 0
    ;;
  1)
    echo "[pre-push] process-gate BLOCKED — resolve findings above. Emergency override is per-gate (e.g. TRELLIS_ALLOW_MAIN_PUSH=1 / SECURITY_GATE_SKIP=1), justified in gotchas.md." >&2
    exit 1
    ;;
  *)
    echo "[pre-push] process-gate exited rc=$rc (unexpected) — blocking (fail-closed)." >&2
    exit 1
    ;;
esac
