#!/usr/bin/env bash
# Trellis worktree-inheritance eager post-checkout hook.
#
# Fires on `git worktree add` (flag $3 == 1, cwd = new worktree).
# Calls seed-inheritance-symlinks.sh to mirror the gitignored .claude/ and
# .agents/ symlinks from the MAIN checkout into the new linked worktree.
#
# NOTE: the seeder is the real logic — this hook is just a thin trigger.
#
# IMPORTANT: this hook only fires if core.hooksPath resolves to a directory
# that EXISTS inside the worktree (tracked dirs like .githooks, or the default
# .git/hooks).  Husky v9 sets core.hooksPath=.husky/_ which is gitignored
# (absent in worktrees) so Husky projects get no benefit from this hook and
# rely on the `trellis worktree` wrapper + SessionStart self-heal instead.
#
# Must NEVER abort worktree creation: set -u but NOT set -e. Always exit 0.

set -u

# ---------------------------------------------------------------------------
# Guard 1: only act on branch/worktree checkouts (git passes $3=1)
# ---------------------------------------------------------------------------
flag="${3:-0}"
if [ "$flag" != "1" ]; then
  exit 0
fi

# ---------------------------------------------------------------------------
# Guard 2: only act in a LINKED worktree (not the main checkout)
# ---------------------------------------------------------------------------
common="$(git rev-parse --git-common-dir 2>/dev/null || true)"
gitdir="$(git rev-parse --git-dir 2>/dev/null || true)"

# If either is empty we're not in a git repo at all → skip
if [ -z "$common" ] || [ -z "$gitdir" ]; then
  exit 0
fi

# In the MAIN checkout common == gitdir (both are .git)
# In a linked worktree gitdir is .git/worktrees/<name> and common is .git
if [ "$common" = "$gitdir" ]; then
  exit 0
fi

# ---------------------------------------------------------------------------
# Resolve TRELLIS_ROOT (to locate the seeder script)
# ---------------------------------------------------------------------------
root=""

# Strategy 1: read the symlink target of .claude/rules/trellis.md in MAIN.
# The first 'worktree <path>' line in `git worktree list --porcelain` is MAIN.
wt_porcelain="$(git worktree list --porcelain 2>/dev/null || true)"
MAIN=""
while IFS= read -r _line; do
  case "$_line" in
    "worktree "*)
      MAIN="${_line#worktree }"
      break ;;
  esac
done <<< "$wt_porcelain"

if [ -n "$MAIN" ] && [ -d "$MAIN" ]; then
  trellis_link="$MAIN/.claude/rules/trellis.md"
  if [ -L "$trellis_link" ]; then
    link_target="$(readlink "$trellis_link" 2>/dev/null || true)"
    # Strip trailing /core-rules/CLAUDE.md
    candidate="${link_target%/core-rules/CLAUDE.md}"
    if [ "$candidate" != "$link_target" ] && [ -d "$candidate" ]; then
      root="$candidate"
    fi
  fi
fi

# Strategy 2: $TRELLIS_ROOT env var
if [ -z "$root" ] && [ -n "${TRELLIS_ROOT:-}" ] && [ -d "${TRELLIS_ROOT:-}" ]; then
  root="$TRELLIS_ROOT"
fi

# Strategy 3: trellis.config.json walk-up from PWD + jq
if [ -z "$root" ] && command -v jq >/dev/null 2>&1; then
  walk="$PWD"
  while [ "$walk" != "/" ]; do
    if [ -f "$walk/trellis.config.json" ]; then
      candidate="$(jq -r '.trellis_root // empty' "$walk/trellis.config.json" 2>/dev/null || true)"
      if [ -n "$candidate" ] && [ -d "$candidate" ]; then
        root="$candidate"
      fi
      break
    fi
    walk="$(dirname "$walk")"
  done
fi

# No root found → exit silently; SessionStart self-heal will handle it
if [ -z "$root" ]; then
  exit 0
fi

# ---------------------------------------------------------------------------
# Invoke the seeder
# ---------------------------------------------------------------------------
seeder="$root/scripts/seed-inheritance-symlinks.sh"
if [ -x "$seeder" ]; then
  "$seeder" --target "$PWD" --quiet || true
fi

exit 0
