{
  "effortLevel": "xhigh",
  "permissions": {
    "deny": [
      "Read(./node_modules/**)",
      "Read(./**/node_modules/**)",
      "Read(./.next/**)",
      "Read(./**/.next/**)",
      "Read(./dist/**)",
      "Read(./**/dist/**)",
      "Read(./build/**)",
      "Read(./**/build/**)",
      "Read(./out/**)",
      "Read(./**/out/**)",
      "Read(./target/**)",
      "Read(./**/target/**)",
      "Read(./vendor/**)",
      "Read(./**/vendor/**)",
      "Read(./.venv/**)",
      "Read(./venv/**)",
      "Read(./**/__pycache__/**)",
      "Read(./.pytest_cache/**)",
      "Read(./.mypy_cache/**)",
      "Read(./.ruff_cache/**)",
      "Read(./coverage/**)",
      "Read(./.coverage)",
      "Read(./.turbo/**)",
      "Read(./.cache/**)",
      "Read(./.parcel-cache/**)",
      "Read(./Library/**)",
      "Read(./Temp/**)",
      "Read(./pnpm-lock.yaml)",
      "Read(./package-lock.json)",
      "Read(./yarn.lock)",
      "Read(./go.sum)",
      "Read(./Cargo.lock)",
      "Read(./poetry.lock)",
      "Read(./uv.lock)",
      "Read(./Pipfile.lock)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-destructive.sh",
            "timeout": 5,
            "statusMessage": "Checking command safety..."
          }
        ]
      },
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/reread-guard.sh",
            "timeout": 5,
            "statusMessage": "Re-read guard..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-verify.sh",
            "timeout": 120,
            "statusMessage": "Verifying edit..."
          }
        ]
      },
      {
        "matcher": "Grep|Bash|Read",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/truncation-check.sh",
            "timeout": 5,
            "statusMessage": "Checking for truncation..."
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/track-read.sh",
            "timeout": 5,
            "statusMessage": "Recording reads..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-context.sh",
            "timeout": 10,
            "statusMessage": "Loading session context..."
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-compact-context.sh",
            "timeout": 10,
            "statusMessage": "Restoring context after compact..."
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/inject-primer-index.sh",
            "timeout": 5,
            "statusMessage": "Loading primer index..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/save-context-log.sh",
            "timeout": 10,
            "statusMessage": "Saving session context..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-verify.sh",
            "timeout": 300,
            "statusMessage": "Running final verification..."
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/code-review-subagent.sh",
            "timeout": 120,
            "statusMessage": "Code review on diff..."
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/propose-rules.sh",
            "timeout": 60,
            "statusMessage": "Proposing rules..."
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ui-verify.sh",
            "timeout": 120,
            "statusMessage": "UI verification..."
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stamp-turn.sh",
            "timeout": 5,
            "statusMessage": "Stamping turn..."
          }
        ]
      }
    ]
  }
}
