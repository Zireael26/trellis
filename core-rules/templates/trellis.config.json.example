{
  "$schema": "./scripts/lib/trellis.config.schema.json",
  "comment": "Example Trellis configuration. Copy to repo root as trellis.config.json, then fill in absolute paths and identity. Never commit secrets here. Pinning trellis_version is optional but recommended for downstream consumers — it tells scripts/upgrade.sh which canonical version this clone is anchored to. harnesses accepts any combination of 'claude', 'codex', and 'antigravity'.",

  "trellis_root": "/ABSOLUTE/PATH/TO/trellis-instance",
  "projects_root": "/ABSOLUTE/PATH/TO/projects",
  "user_home": "/ABSOLUTE/PATH/TO/home",

  "maintainer_name": "Your Name",
  "github_user": "your-github-handle",

  "harnesses": ["claude", "codex", "antigravity"],

  "autonomy_default": 3,
  "comment_autonomy_default": "Optional. Fleet autonomy level 1–5; default 3 (current Trellis behavior). 1=pedagogical, 2=cautious, 3=standard, 4=initiative, 5=autonomous. Per-project override via <project>/.trellis.config.json autonomy field. Presets may clamp via autonomy_ceiling.",

  "trellis_version": "0.1.0",

  "template": {
    "remote": "git@github.com:your-org/trellis.git",
    "branch": "main"
  },

  "sed_flavor": "auto",

  "approved_mcps": [
    { "name": "scheduled-tasks", "purpose": "Trellis weekly + quarterly audits", "scope": "fleet" },
    { "name": "computer-use", "purpose": "Native-app screenshots + UI control for ui-verify fallback", "scope": "fleet" },
    { "name": "claude-in-chrome", "purpose": "Browser navigation + DOM-aware actions", "scope": "fleet" }
  ]
}
