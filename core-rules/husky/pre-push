#!/usr/bin/env sh
# Trellis canonical pre-push.
# 1. Blocks direct pushes to main/master (Trellis PR-flow policy).
#    Override for emergencies: TRELLIS_ALLOW_MAIN_PUSH=1 git push
# 2. Runs typecheck then test scripts if present. Missing scripts skip with log line.

set -e

# --- Trellis PR-flow guard ---
# Git passes refs via stdin: <local_ref> <local_sha> <remote_ref> <remote_sha>
while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/master)
      if [ "${TRELLIS_ALLOW_MAIN_PUSH:-0}" != "1" ]; then
        echo "[pre-push] Direct push to $remote_ref blocked by Trellis policy." >&2
        echo "[pre-push] Open a branch + PR. Emergency override: TRELLIS_ALLOW_MAIN_PUSH=1 git push" >&2
        exit 1
      fi
      echo "[pre-push] TRELLIS_ALLOW_MAIN_PUSH=1 set; allowing direct push to $remote_ref." >&2
      ;;
  esac
done

command -v node >/dev/null 2>&1 || { echo "[pre-push] node unavailable; skipping"; exit 0; }

# --- package-manager resolution (config-driven; "auto"/unset = lockfile detect) ---
# Inlined mirror of core-rules/hooks/lib/pm.sh:trellis_resolve_pm — husky hooks
# are git-level + seeded once and cannot reliably source the synced
# .claude/hooks/lib copy. Keep the resolution + lockfile order in sync.
PM=""
if command -v jq >/dev/null 2>&1; then
  for _cand in .trellis.config.json trellis.config.json; do
    [ -f "$_cand" ] || continue
    PM="$(jq -r '.package_manager // empty' "$_cand" 2>/dev/null)"
    [ -n "$PM" ] && break
  done
  if [ -z "$PM" ] && [ -n "${TRELLIS_ROOT:-}" ] && [ -f "$TRELLIS_ROOT/trellis.config.json" ]; then
    PM="$(jq -r '.package_manager // empty' "$TRELLIS_ROOT/trellis.config.json" 2>/dev/null)"
  fi
fi
if [ -z "$PM" ] || [ "$PM" = "auto" ]; then
  if   [ -f pnpm-lock.yaml ];                 then PM=pnpm
  elif [ -f bun.lock ] || [ -f bun.lockb ];   then PM=bun
  elif [ -f yarn.lock ];                      then PM=yarn
  elif [ -f package-lock.json ];              then PM=npm
  else                                             PM=npm
  fi
fi

# Configured-but-missing PM → skip verification rather than block the push.
PM_OK=1
if ! command -v "$PM" >/dev/null 2>&1; then
  echo "[pre-push] package manager '$PM' not on PATH — skipping typecheck/test" >&2
  PM_OK=0
fi

has_script() {
  node -e "const p=require('./package.json');process.exit((p.scripts||{})['$1']?0:1)" 2>/dev/null
}
run_script() {
  "$PM" run "$1"
}

echo "[pre-push] Trellis verification starting..."

if [ "$PM_OK" = 1 ] && has_script typecheck; then
  run_script typecheck || { echo "[pre-push] typecheck failed"; exit 1; }
else
  echo "[pre-push] no typecheck script - skipping"
fi

if [ "$PM_OK" = 1 ] && has_script test; then
  run_script test || { echo "[pre-push] tests failed"; exit 1; }
else
  echo "[pre-push] no test script - skipping"
fi

# --- security-gate diff scan ---
# Mode 2: scopes scanners to changed files, dedupes against the latest baseline JSON.
# Skipped (warn) when no baseline exists. Fails the push only on new Critical/High.
# Override: SECURITY_GATE_SKIP=1 git push
if [ "${SECURITY_GATE_SKIP:-0}" = "1" ]; then
  echo "[pre-push] SECURITY_GATE_SKIP=1 — skipping security-gate diff"
elif [ -x .claude/skills/security-gate/scripts/run-diff.sh ]; then
  echo "[pre-push] security-gate diff scan..."
  if ! bash .claude/skills/security-gate/scripts/run-diff.sh; then
    rc=$?
    if [ "$rc" = "1" ]; then
      echo "[pre-push] security-gate BLOCKED — new Critical/High findings. Justify with SECURITY_GATE_SKIP=1 only in emergencies." >&2
      exit 1
    fi
    # rc=2 (NEEDS CHANGES, warn-only) is non-blocking.
  fi
elif [ -x .agents/skills/security-gate/scripts/run-diff.sh ]; then
  echo "[pre-push] security-gate diff scan (codex)..."
  if ! bash .agents/skills/security-gate/scripts/run-diff.sh; then
    rc=$?
    if [ "$rc" = "1" ]; then
      echo "[pre-push] security-gate BLOCKED — new Critical/High findings. Justify with SECURITY_GATE_SKIP=1 only in emergencies." >&2
      exit 1
    fi
  fi
else
  echo "[pre-push] security-gate not symlinked — skipping (run scripts/onboard-project.sh to install)"
fi

echo "[pre-push] ok"
